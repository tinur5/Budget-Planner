# ============================================================
# Familie Budget Planner – Umgebungsvariablen
# ============================================================
# Kopiere diese Datei zu .env und passe die Werte an:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Datenbank
# ------------------------------------------------------------
# Lokal (SQLite – kein Datenbankserver nötig):
DATABASE_URL="file:./prisma/dev.db"

# Produktion (PostgreSQL):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/budget_planner?schema=public"

# ------------------------------------------------------------
# NextAuth.js Authentifizierung
# ------------------------------------------------------------
# Geheimer Schlüssel zum Signieren von JWTs / Sessions
# Für Produktion: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# Öffentliche URL der App
# Lokal:
NEXTAUTH_URL="http://localhost:3000"
# Produktion: https://ihre-domain.ch
